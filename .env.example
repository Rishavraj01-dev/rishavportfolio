# Public canonical site URL used for SEO metadata.
# Use your final production domain only. Do not use localhost or preview URLs.
VITE_SITE_URL=https://your-domain.com

# Optional compatibility alias for Next-style deployments.
# This project is Vite, and vite.config.ts exposes NEXT_PUBLIC_* safely for public values only.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional Search Console verification token. This is public verification metadata, not a secret.
VITE_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
